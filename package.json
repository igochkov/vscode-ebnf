{
    "name": "vscode-ebnf",
    "displayName": "EBNF Tools",
    "description": "EBNF Tools for Visual Studio Code",
    "version": "1.5.0",
    "publisher": "igochkov",
    "author": {
        "name": "Ivaylo Gochkov",
        "url": "https://github.com/igochkov"
    },
    "icon": "images/icon.png",
    "engines": {
        "vscode": "^1.101.0"
    },
    "license": "MIT",
    "categories": [
        "Programming Languages",
        "Education",
        "Formatters"
    ],
    "keywords": [
        "ebnf",
        "bnf"
    ],
    "capabilities": {
        "documentFormattingProvider": "true",
        "documentRangeFormattingProvider": "true",
        "documentOnTypeFormattingProvider": "true",
        "definitionProvider": "true",
        "renameProvider": "true",
        "codeActionProvider": "true",
        "referencesProvider": "true",
        "completionProvider": "true",
        "hoverProvider": "true",
        "documentSymbolProvider": "true",
        "documentHighlightProvider": "true",
        "foldingRangeProvider": "true",
        "codeLensProvider": "true",
        "documentSemanticTokensProvider": "true"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/igochkov/vscode-ebnf.git"
    },
    "homepage": "https://github.com/igochkov/vscode-ebnf",
    "bugs": {
        "url": "https://github.com/igochkov/vscode-ebnf/issues"
    },
    "sponsor": {
        "url": "https://github.com/sponsors/igochkov"
    },
    "contributes": {
        "languages": [
            {
                "id": "ebnf",
                "aliases": [
                    "EBNF",
                    "Extended Backus-Naur Form"
                ],
                "extensions": [
                    ".ebnf"
                ],
                "configuration": "syntaxes/ebnf.configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "ebnf",
                "scopeName": "source.ebnf",
                "path": "syntaxes/ebnf.tmLanguage.json"
            },
            {
                "scopeName": "markdown.ebnf.codeblock",
                "path": "./syntaxes/codeblock.json",
                "injectTo": [
                    "text.html.markdown"
                ],
                "embeddedLanguages": {
                    "meta.embedded.block.ebnf": "ebnf"
                }
            }
        ],
        "commands": [
            {
                "command": "ebnf.convertIdentifiers",
                "title": "Convert identifiers…",
                "category": "EBNF"
            }
        ],
        "menus": {
            "commandPalette": [
                {
                    "command": "ebnf.convertIdentifiers",
                    "when": "editorLangId == ebnf"
                }
            ]
        },
        "configuration": {
            "title": "EBNF",
            "properties": {
                "EBNF.format.enable": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable/disable default EBNF formatter.",
                    "order": 0
                },
                "EBNF.format.definingSymbolOnNewLine": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "Place defining symbol `\"=\"` on new line.",
                    "order": 1
                },
                "EBNF.format.indentDefiningSymbol": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "Indent defining symbol `\"=\"` when on new line.\n\n`#editor.tabSize#` and `#editor.insertSpaces#` can be configured in the **Commonly Used** section.",
                    "order": 2
                },
                "EBNF.format.terminatorSymbolOnNewLine": {
                    "type": "boolean",
                    "default": false,
                    "markdownDescription": "Place terminator symbol (`\";\"` or `\".\"`) on new line.",
                    "order": 3
                },
                "EBNF.format.definitionSeparatorSymbolOnNewLine": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "Place definition separator symbol (`\"|\"`, `\"/\"` or `\"!\"`)  on new line.",
                    "order": 4
                },
                "EBNF.format.insertSpaceBeforeConcatenateSymbol": {
                    "type": "boolean",
                    "default": false,
                    "markdownDescription": "Insert space before concatenate symbol `\",\"`.",
                    "order": 5
                },
                "EBNF.format.insertSpaceAtSequenceSymbols": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "Insert space at sequence symbols (`\"{\"`, `\"}\"`, `\"(\"`, `\")\"`, `\"[\"`, `\"]\"`).",
                    "order": 6
                },
                "EBNF.format.defaultDefinitionSeparatorSymbol": {
                    "type": "string",
                    "default": "|",
                    "enum": [
                        "|",
                        "/",
                        "!"
                    ],
                    "order": 10
                },
                "EBNF.format.defaultOptionSymbols": {
                    "type": "string",
                    "default": "[ ]",
                    "enum": [
                        "[ ]",
                        "(/ /)"
                    ],
                    "order": 11
                },
                "EBNF.format.defaultRepeatSymbols": {
                    "type": "string",
                    "default": "{ }",
                    "enum": [
                        "{ }",
                        "(: :)"
                    ],
                    "order": 12
                },
                "EBNF.format.defaultTerminatorSymbol": {
                    "type": "string",
                    "default": ";",
                    "enum": [
                        ";",
                        "."
                    ],
                    "order": 13
                },
                "EBNF.identifierStyle": {
                    "type": "string",
                    "enum": [
                        "modern",
                        "standard"
                    ],
                    "default": "modern",
                    "enumDescriptions": [
                        "Allow underscores in identifiers (e.g. \"my_rule\"). Hyphens ('-') are still accepted but deprecated, because '-' is the EBNF except-symbol. Backward-compatible default.",
                        "Aim for strict ISO/IEC 14977 identifiers (letters and digits). Currently flags hyphens as non-standard; underscore and space-separated-identifier handling arrive with future release."
                    ],
                    "markdownDescription": "Which meta-identifier characters are considered valid.\n\n- **modern** (default): underscores are allowed; hyphens (`-`) are **deprecated** because `-` is the EBNF *except-symbol*.\n- **standard**: strict ISO/IEC 14977 (letters and digits).\n\nFor now this only affects diagnostics — parsing is unchanged and remains backward-compatible. See [issue #36](https://github.com/igochkov/vscode-ebnf/issues/36).",
                    "order": 14
                },
                "EBNF.telemetry.enable": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "Send anonymous usage telemetry: at most one event per day recording only *whether* you used hyphen/underscore/space-separated identifiers that day. **No** device ID, grammar text, identifier names, file names, or paths are ever sent. Also requires VS Code's global telemetry to be enabled (see `#telemetry.telemetryLevel#`).",
                    "tags": [
                        "telemetry",
                        "usesOnlineServices"
                    ],
                    "order": 20
                }
            }
        }
    },
    "dependencies": {
        "antlr-ng": "^1.0.10",
        "antlr4ng": "^3.0.16",
        "assert": "^2.1.0",
        "util": "^0.12.5"
    },
    "overrides": {
        "js-yaml": "^3.15.0",
        "@babel/core": "^7.29.6"
    },
    "main": "./dist/extension.js",
    "scripts": {
        "vscode:prepublish": "npm run package",
        "build": "webpack --mode development",
        "package": "webpack --mode production",
        "typecheck": "tsc --noEmit",
        "generate": "antlr-ng -o src/parser --exact-output-dir true -l true -v true grammar/EBNFLexer.g4 grammar/EBNFParser.g4 -D language=TypeScript",
        "test": "jest"
    },
    "devDependencies": {
        "@types/jest": "^30.0.0",
        "@types/node": "^20.19.1",
        "@types/vscode": "^1.101.0",
        "antlr-ng": "^1.0.10",
        "jest": "^30.0.3",
        "ts-jest": "^29.4.0",
        "ts-loader": "^9.5.2",
        "webpack": "^5.105.0",
        "webpack-cli": "^5.1.4"
    }
}